# Copiar a .env y rellenar. .env está en .gitignore — NUNCA commitear keys.

# --- Supabase (proyecto cloud; en dev se usa el mismo, no hay DB local) ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=            # frontend (login)
SUPABASE_JWT_SECRET=          # backend: verificación de JWT (Settings → API)
# Conexión del backend — usar el rol app_backend (SIN bypassrls), no el service role:
DATABASE_URL=postgresql+asyncpg://app_backend:<pass>@<pooler-host>:6543/postgres

# --- Keys master de proveedores (modo reseller) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- Envelope encryption de keys BYOK (D2). Generar: openssl rand -base64 32 ---
APP_MASTER_KEY=

# --- Dominios ---
BASE_DOMAIN=lvh.me            # local: http://<slug>.lvh.me:3000 → 127.0.0.1
